} from 'lucide-react';

export default function App() {
  // --- CORE STATE ---
  const [price, setPrice] = useState(0);
  const [balance, setBalance] = useState(100000.00); 
  const [positions, setPositions] = useState([]);
  const [algoActive, setAlgoActive] = useState(false);
  const [chartData, setChartData] = useState([]); // Array of close prices
  const [connectionStatus, setConnectionStatus] = useState('VERBINDEN...');
  
  // --- ADVANCED 5M QUANT METRICS ---
  const [atr, setAtr] = useState(0); 
  const [rsi, setRsi] = useState(50);
  const [bollinger, setBollinger] = useState({ upper: 0, lower: 0, mid: 0 });
  const [sentimentScore, setSentimentScore] = useState(0.5); 
  
  const [terminalLogs, setTerminalLogs] = useState([]);
  const wsRef = useRef(null);

  // Telegram Integration Hook
  useEffect(() => {
    // If running inside Telegram, expand the WebApp to full screen
    if (window.Telegram && window.Telegram.WebApp) {
      window.Telegram.WebApp.expand();
      window.Telegram.WebApp.setHeaderColor('#0B0E14');
    }
  }, []);

  const addLog = useCallback((msg, type = 'info') => {
    setTerminalLogs(prev => [{ time: new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', second:'2-digit'}), text: msg, type }, ...prev].slice(0, 15));
  }, []);

  // --- LIVE DATA ENGINE (Binance 5m WS) ---
  useEffect(() => {
    addLog("System Boot... Vaultagi TG-Engine (5m) aktiv.", "system");

    const fetchHistory = async () => {
      try {
        const res = await fetch('https://api.binance.com/api/v3/klines?symbol=PAXGUSDT&interval=5m&limit=50');
        const data = await res.json();
        const closes = data.map(d => parseFloat(d[4]));
        setChartData(closes);
        setPrice(closes[closes.length - 1]);
        calculateIndicators(closes);
      } catch (err) {
        addLog("API Error. Fallback init.", "bear");
      }
    };

    fetchHistory();

    const connectWS = () => {
      // 5 Minute Kline Stream
      const ws = new WebSocket('wss://stream.binance.com:9443/ws/paxgusdt@kline_5m');
      wsRef.current = ws;

      ws.onopen = () => {
        setConnectionStatus('LIVE');
        addLog("WebSocket Sync: XAU/USD 5m Pool.", "bull");
      };

      ws.onmessage = (event) => {
        const message = JSON.parse(event.data);
        const candle = message.k;
        const currentPrice = parseFloat(candle.c);
        const isFinal = candle.x; // Trigger only on candle close

        setPrice(currentPrice);

        setChartData(prev => {
          const newData = [...prev];
          newData[newData.length - 1] = currentPrice;
          return newData;
        });

        if (isFinal) {
          addLog(`5m Block Mined @ ${currentPrice.toFixed(2)}`, "info");
          setChartData(prev => {
            const updated = [...prev.slice(1), currentPrice];
            calculateIndicators(updated, currentPrice);
            return updated;
          });
        }
      };

      ws.onclose = () => {
        setConnectionStatus('RECONNECT');
        setTimeout(connectWS, 3000);
      };
    };

    connectWS();
    return () => { if (wsRef.current) wsRef.current.close(); };
  }, [addLog]);

  // --- HFT MATH ENGINE ---
  const calculateIndicators = (closes, currentPriceClose = null) => {
    if (closes.length < 20) return;

    // 1. ATR (Volatility)
    let trSum = 0;
    for(let i = Math.max(1, closes.length - 14); i < closes.length; i++) {
      trSum += Math.abs(closes[i] - closes[i-1]);
    }
    const currentAtr = Number((trSum / 14).toFixed(2));
    setAtr(currentAtr);

    // 2. Bollinger Bands (20 Period, 2 StdDev)
    const period = 20;
    const slice = closes.slice(-period);
    const sma = slice.reduce((a,b) => a+b, 0) / period;
    
    const squaredErrors = slice.map(val => Math.pow(val - sma, 2));
    const variance = squaredErrors.reduce((a,b) => a+b, 0) / period;
    const stdDev = Math.sqrt(variance);
    
    const bands = {
      mid: sma,
      upper: sma + (stdDev * 2),
      lower: sma - (stdDev * 2)
    };
    setBollinger(bands);

    // 3. Simple RSI (14 Period)
    let gains = 0, losses = 0;
    for(let i = closes.length - 14; i < closes.length; i++) {
      const diff = closes[i] - closes[i-1];
      if (diff >= 0) gains += diff;
      else losses -= diff;
    }
    const avgGain = gains / 14;
    const avgLoss = losses / 14;
    const rs = avgLoss === 0 ? 100 : avgGain / avgLoss;
    const currentRsi = 100 - (100 / (1 + rs));
    setRsi(currentRsi);

    // Trigger Logic Engine
    evaluateTradingLogic(currentPriceClose || closes[closes.length-1], currentAtr, bands, currentRsi);
  };

  // --- THE "SNIPER" TRADING LOGIC ---
  const evaluateTradingLogic = (currentPrice, currentAtr, bands, currentRsi) => {
    if (!algoActive) return;

    const equity = calcEquity();

    // Max 1 offenen Trade bei 5m um Exposure zu minimieren
    if (positions.length < 1) { 
      let signal = null;

      // STRATEGIE: Bollinger Reversion + RSI Extreme (The Holy Grail of 5m)
      const isOversold = currentRsi < 30;
      const isOverbought = currentRsi > 70;
      const sweptLower = currentPrice < bands.lower;
      const sweptUpper = currentPrice > bands.upper;

      if (isOversold && sweptLower) {
        signal = 'BUY';
        addLog(`⚡ SMC SWEEP: Liquidity unterhalb BB gefischt. RSI: ${currentRsi.toFixed(0)}`, 'system');
      } else if (isOverbought && sweptUpper) {
        signal = 'SELL';
        addLog(`⚡ SMC SWEEP: Liquidity oberhalb BB gefischt. RSI: ${currentRsi.toFixed(0)}`, 'system');
      }

      // Execute Trade with tighter 5m Risk Params
      if (signal) {
        // 1.5% Risk, tighter stops for 5m
        const RISK_PCT = 0.015; 
        const riskAmount = equity * RISK_PCT;
        // Stop is ATR * 1.2 (Tighter for 5m)
        const stopDistance = Math.max(currentAtr * 1.2, 1.5); 
        
        let size = riskAmount / (stopDistance * 10);
        size = Math.max(0.1, Math.min(Number(size.toFixed(2)), 10.0)); 

        const sl = signal === 'BUY' ? currentPrice - stopDistance : currentPrice + stopDistance;
        // RR 1:2 is more realistic for 5m scalping
        const tp = signal === 'BUY' ? currentPrice + (stopDistance * 2) : currentPrice - (stopDistance * 2);

        const newPos = { 
          id: Date.now().toString(), 
          type: signal, 
          entry: currentPrice, 
          size: size,
          sl: Number(sl.toFixed(2)),
          tp: Number(tp.toFixed(2)),
          trailingActive: false
        };

        setPositions([...positions, newPos]);
        addLog(`🎯 EXECUTION: ${signal} @ ${currentPrice.toFixed(2)} | Size: ${size}L`, 'system');
      }
    }
  };

  // --- POSITION MONITORING (Tick by Tick) ---
  useEffect(() => {
    if (!algoActive || positions.length === 0 || price === 0) return;

    positions.forEach(pos => {
      const isLong = pos.type === 'BUY';
      const points = isLong ? price - pos.entry : pos.entry - price;
      const pnl = points * (pos.size * 10);

      if ((isLong && price <= pos.sl) || (!isLong && price >= pos.sl)) {
        closeTrade(pos.id, 'Stop Loss', pnl);
      } else if ((isLong && price >= pos.tp) || (!isLong && price <= pos.tp)) {
        closeTrade(pos.id, 'Take Profit', pnl);
      } else if (points > atr && !pos.trailingActive) {
        updatePosition(pos.id, { trailingActive: true, sl: pos.entry });
        addLog(`🛡️ Break-Even gesichert (#${pos.id.slice(-3)})`, 'info');
      }
    });
  }, [price, algoActive, positions, atr, addLog]);

  const closeTrade = (id, reason, pnl) => {
    setPositions(prev => prev.filter(p => p.id !== id));
    setBalance(b => b + pnl);
    addLog(`💸 CLOSE (${reason}): ${pnl > 0 ? '+' : ''}$${pnl.toFixed(2)}`, pnl > 0 ? 'bull' : 'bear');
  };

  const updatePosition = (id, updates) => {
    setPositions(prev => prev.map(p => p.id === id ? { ...p, ...updates } : p));
  };

  const calcEquity = () => {
    let floating = 0;
    positions.forEach(pos => {
      const diff = pos.type === 'BUY' ? price - pos.entry : pos.entry - price;
      floating += diff * (pos.size * 10);
    });
    return balance + floating;
  };

  const equity = calcEquity();
  const floatingPnL = equity - balance;

  if (price === 0) {
    return (
      <div className="min-h-[100dvh] bg-[#0B0E14] flex flex-col items-center justify-center text-slate-400 font-mono">
        <Globe className="animate-spin text-amber-500 mb-4" size={32} />
        <p className="text-sm">VAULTAGI TG LINK...</p>
      </div>
    );
  }

  return (
    <div className="min-h-[100dvh] bg-[#0B0E14] text-slate-300 font-sans selection:bg-amber-500/30 flex flex-col">
      
      {/* MOBILE HEADER */}
      <header className="sticky top-0 z-50 bg-[#0B0E14]/90 backdrop-blur-md border-b border-slate-800 p-4">
        <div className="flex justify-between items-center">
          <div className="flex items-center gap-2">
            <div className="w-8 h-8 rounded-lg bg-amber-500/10 flex items-center justify-center border border-amber-500/20">
              <Smartphone className="text-amber-400" size={18} />
            </div>
            <div>
              <h1 className="text-lg font-bold text-white tracking-tight leading-none">VAULTAGI</h1>
              <p className="text-[10px] text-slate-500 uppercase tracking-widest mt-0.5 flex items-center gap-1">
                5M Sniper 
                <span className={`w-1.5 h-1.5 rounded-full ${connectionStatus === 'LIVE' ? 'bg-emerald-500 animate-pulse' : 'bg-rose-500'}`}></span>
              </p>
            </div>
          </div>
          <div className="text-right">
            <p className="text-[10px] text-slate-500 font-semibold tracking-wider uppercase">Equity</p>
            <p className="text-lg font-mono text-white leading-none">${equity.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits:2})}</p>
          </div>
        </div>
      </header>

      {/* MAIN SCROLLABLE AREA */}
      <div className="flex-1 overflow-y-auto p-4 space-y-4 pb-24">
        
        {/* PRICE & MINI CHART */}
        <div className="bg-[#111620] rounded-2xl border border-slate-800 p-4 relative overflow-hidden">
          <div className="flex justify-between items-end mb-4">
            <div>
              <span className="text-[10px] text-slate-500 font-bold uppercase tracking-wider mb-1 block">XAU/USD (PAXG)</span>
              <h2 className={`text-4xl font-mono tracking-tighter transition-colors duration-300 ${chartData[chartData.length-1] >= chartData[chartData.length-2] ? 'text-emerald-400' : 'text-rose-400'}`}>
                {price.toFixed(2)}
              </h2>
            </div>
            <div className="text-right">
              <span className="text-[10px] text-slate-500 font-bold uppercase block mb-1">RSI (14)</span>
              <span className={`font-mono text-lg font-bold ${rsi > 70 ? 'text-rose-400' : rsi < 30 ? 'text-emerald-400' : 'text-amber-400'}`}>
                {rsi.toFixed(1)}
              </span>
            </div>
          </div>

          {/* Compact Chart with Bollinger Bands */}
          <div className="h-32 w-full border border-slate-800/50 bg-[#0B0E14] rounded-xl relative overflow-hidden">
             <div className="absolute inset-0 flex items-end">
                  <svg width="100%" height="100%" preserveAspectRatio="none" className="overflow-visible">
                    {(() => {
                      const visibleData = chartData.slice(-30);
                      if (visibleData.length < 2 || !bollinger.upper) return null;
                      
                      // Scale based on Bollinger Bands to keep them in view
                      const min = bollinger.lower - (atr * 0.5);
                      const max = bollinger.upper + (atr * 0.5);
                      const range = max - min || 1;
                      
                      const points = visibleData.map((val, i) => {
                        const x = (i / (visibleData.length - 1)) * 100;
                        const y = 100 - (((val - min) / range) * 100);
                        return `${x},${y}`;
                      }).join(' ');

                      // Bollinger Band Lines
                      const bbUpperY = 100 - (((bollinger.upper - min) / range) * 100);
                      const bbLowerY = 100 - (((bollinger.lower - min) / range) * 100);

                      return (
                        <>
                          {/* BB Fill */}
                          <rect x="0" y={bbUpperY + "%"} width="100%" height={(bbLowerY - bbUpperY) + "%"} fill="#334155" fillOpacity="0.1" />
                          <line x1="0" y1={bbUpperY + "%"} x2="100%" y2={bbUpperY + "%"} stroke="#64748b" strokeWidth="1" strokeDasharray="4" strokeOpacity="0.3"/>
                          <line x1="0" y1={bbLowerY + "%"} x2="100%" y2={bbLowerY + "%"} stroke="#64748b" strokeWidth="1" strokeDasharray="4" strokeOpacity="0.3"/>
                          
                          {/* Price Line */}
                          <polyline points={points} fill="none" stroke="#fbbf24" strokeWidth="2" vectorEffect="non-scaling-stroke" strokeLinejoin="round" />
                          <circle cx="100%" cy={`${100 - (((price - min) / range) * 100)}%`} r="4" fill="#10b981" className="animate-pulse"/>
                        </>
                      );
                    })()}
                  </svg>
                </div>
          </div>
        </div>

        {/* CONTROLS */}
        <div className="bg-[#111620] rounded-2xl border border-slate-800 p-4">
           <button 
              onClick={() => setAlgoActive(!algoActive)}
              className={`w-full py-4 rounded-xl font-bold uppercase tracking-widest text-sm flex justify-center items-center gap-2 transition-all duration-200 shadow-lg ${
                algoActive 
                  ? 'bg-rose-500/10 text-rose-500 border border-rose-500/50' 
                  : 'bg-emerald-500 text-[#0B0E14] active:scale-95'
