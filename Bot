            </button>
            <div className="mt-3 flex justify-between text-[10px] text-slate-500 uppercase font-mono px-2">
              <span>Risk: 1.5%</span>
              <span>Filter: BB + RSI</span>
              <span>Pos: {positions.length}/1</span>
            </div>
        </div>

        {/* POSITIONS */}
        {positions.length > 0 && (
          <div className="space-y-3">
            <h3 className="text-[10px] font-bold text-slate-500 uppercase tracking-wider px-2">Active Trade</h3>
            {positions.map(pos => {
              const isLong = pos.type === 'BUY';
              const pnl = (isLong ? price - pos.entry : pos.entry - price) * (pos.size * 10);
              const isProfit = pnl >= 0;

              return (
                <div key={pos.id} className="bg-slate-900 p-4 rounded-2xl border border-slate-800 relative overflow-hidden">
                  {pos.trailingActive && <div className="absolute left-0 top-0 w-1 h-full bg-emerald-500"></div>}
                  <div className="flex justify-between items-start mb-4">
                    <div className="flex flex-col">
                       <span className={`w-min px-2 py-0.5 rounded text-[10px] font-bold uppercase mb-1 ${isLong ? 'bg-emerald-500/20 text-emerald-400' : 'bg-rose-500/20 text-rose-400'}`}>
                        {pos.type}
                      </span>
                      <span className="text-white font-mono text-sm">{pos.size.toFixed(2)} Lots</span>
                    </div>
                    <div className="text-right">
                      <p className={`font-mono font-bold text-2xl leading-none ${isProfit ? 'text-emerald-400' : 'text-rose-400'}`}>
                        {isProfit ? '+' : ''}${pnl.toFixed(2)}
                      </p>
                      <p className="text-[10px] text-slate-500 font-mono mt-1">ENTRY: {pos.entry.toFixed(2)}</p>
                    </div>
                  </div>
                  
                  <div className="flex gap-2">
                     <button onClick={() => closeTrade(pos.id, 'Manual', pnl)} className="flex-1 py-2 bg-slate-800 text-slate-300 rounded-lg text-xs font-bold uppercase border border-slate-700 active:bg-slate-700">
                        Close
                     </button>
                     <div className="flex-1 bg-[#0B0E14] rounded-lg border border-slate-800 flex flex-col justify-center items-center text-[10px] font-mono">
                        <span className="text-slate-500">TP / SL</span>
                        <span className="text-white">{pos.tp.toFixed(1)} / <span className="text-amber-400">{pos.sl.toFixed(1)}</span></span>
                     </div>
                  </div>
                </div>
              )
            })}
          </div>
        )}

        {/* TERMINAL LOG */}
        <div>
          <h3 className="text-[10px] font-bold text-slate-500 uppercase tracking-wider px-2 mb-2">Live Stream</h3>
          <div className="bg-[#111620] rounded-2xl border border-slate-800 p-3 h-40 overflow-y-auto font-mono text-[10px] space-y-2">
            {terminalLogs.map((log, i) => (
              <div key={i} className={`flex gap-2 ${i === 0 ? 'opacity-100' : 'opacity-60'}`}>
                <span className="text-slate-600 shrink-0">[{log.time}]</span>
                <span className={`
                  ${log.type === 'system' ? 'text-amber-400' : ''}
                  ${log.type === 'bull' ? 'text-emerald-400' : ''}
                  ${log.type === 'bear' ? 'text-rose-400' : ''}
                  ${log.type === 'info' ? 'text-slate-300' : ''}
                `}>
                  {log.text}
                </span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  );
}

function PowerIcon({ size }) {
  return (
    <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
      <path d="M18.36 6.64a9 9 0 1 1-12.73 0"></path>
      <line x1="12" y1="2" x2="12" y2="12"></line>
    </svg>
  );
}


